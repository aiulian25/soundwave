# SoundWave Configuration
# SW_HOST must be the public URL clients use. IN PRODUCTION BEHIND HTTPS set this to
# your https:// URL (e.g. https://music.example.com) — otherwise Secure cookies/HSTS
# stay OFF (see SECURE_COOKIES below).
SW_HOST=http://localhost:8889
SW_USERNAME=admin

# --- HTTPS / cookie security (DEP-05/06) ----------------------------------------
# When served over HTTPS (behind nginx/Cloudflare/Traefik), UNCOMMENT these so
# session/CSRF cookies get the `Secure` flag and HSTS is sent. Leave commented for
# plain-HTTP LAN/dev (Secure cookies are NOT sent over http and would break login).
# SECURE_COOKIES=true
# SSL_REDIRECT=True
# Default proxy header is X-Forwarded-Proto; ensure your reverse proxy sets it.
# Initial admin password used ONLY to bootstrap the first admin account.
# Leave blank to be forced to set one, or generate a strong value:
#   openssl rand -base64 24
# The admin is REQUIRED to change this on first login. Do NOT ship a weak default.
SW_PASSWORD=
# --- Service passwords (DEP-01) -------------------------------------------------
# Generate a STRONG, UNIQUE value for each (do NOT reuse). Use only URL-safe chars
# since some are embedded in connection URLs:
#   openssl rand -hex 24
# `setup.sh` fills these automatically for new installs; for an existing deployment
# rotate them with `scripts/rotate-secrets.sh` (it updates the live DB/cache too).
ELASTIC_PASSWORD=
REDIS_HOST=soundwave-redis
REDIS_PASSWORD=
ES_URL=http://soundwave-es:9200

# PostgreSQL
POSTGRES_USER=soundwave
POSTGRES_DB=soundwave
POSTGRES_PASSWORD=
TZ=UTC

# Number of trusted reverse proxies in front of the app (anti-IP-spoofing for login
# lockout + rate limiting). Leave blank for direct exposure. Behind nginx/Cloudflare/
# Traefik etc., set to the proxy hop count (usually 1) so real client IPs are used.
NUM_PROXIES=

# Email / SMTP (optional). Required to verify email-address changes. When EMAIL_HOST
# is set, changing an email sends a confirmation link and only applies once confirmed.
# Without SMTP, email changes keep the existing password-gated immediate behavior.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=SoundWave <no-reply@localhost>
# Force email-change verification even without SMTP (changes will fail to send if so).
# EMAIL_VERIFICATION_REQUIRED=true

# CORS Configuration - Add your custom domains here (comma-separated)
# Default: http://localhost:8889,https://localhost:8889
# Example with custom domain: http://localhost:8889,https://localhost:8889,https://yourdomain.com
CORS_ORIGINS=http://localhost:8889,https://localhost:8889

# Django host validation
# Use explicit hosts in production. Keep ALLOW_LOCAL_NETWORK=false unless you need local LAN access in dev.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ALLOW_LOCAL_NETWORK=true
LOCAL_NETWORK_IPS=

# Security toggles
WTF_CSRF_ENABLED=true
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=

# Optional settings
# yt-dlp is pinned in the image (CNT-02) and updated via image rebuilds/PRs, not at
# runtime (the runtime container is read-only and has no pip). Keep this false.
SW_AUTO_UPDATE_YTDLP=false
DJANGO_DEBUG=false

# Django secret key (required for production)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Last.fm API (for metadata and artwork)
# Register at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key-here
LASTFM_API_SECRET=

# Fanart.tv API (for high quality artwork)
# Register at: https://fanart.tv/get-an-api-key/
FANART_API_KEY=your-fanart-api-key-here
